# Firebase Client Config (from Firebase Console > Project Settings > General)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Site access — password to enter the website (leave empty to disable gate)
SITE_ACCESS_PASSWORD=Alexandera54321

# Your owner/admin email — sign up with this email to get full admin access
NEXT_PUBLIC_ADMIN_EMAIL=ridaimran314@gmail.com

# Same email for Cloud Functions (set via: firebase functions:config:set admin.email="your@email.com")
# Or set ADMIN_EMAIL in Firebase Functions environment variables
ADMIN_EMAIL=ridaimran314@gmail.com

# Site Configuration
NEXT_PUBLIC_SITE_NAME=FASTVault
NEXT_PUBLIC_CONTACT_EMAIL=contact@fastvault.example.com
NEXT_PUBLIC_FACEBOOK_GROUP=https://facebook.com/groups/fastvault
NEXT_PUBLIC_BUILDER_NAME=Your Name
NEXT_PUBLIC_BUILDER_PORTFOLIO=https://yourportfolio.com

# Firebase Admin (for seed script only - keep secret)
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json
