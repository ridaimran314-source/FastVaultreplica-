rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }
    function isAdmin() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }
    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    match /users/{uid} {
      allow read: if true;
      allow create: if isOwner(uid) &&
        request.resource.data.role in ["student", "admin"];
      allow update: if isAdmin() ||
        (isOwner(uid) &&
          request.resource.data.role == resource.data.role &&
          request.resource.data.email == resource.data.email);
      allow delete: if isAdmin();
    }

    match /resources/{id} {
      allow read: if resource.data.status == "published" || isAdmin() ||
        (isSignedIn() && resource.data.uploaded_by == request.auth.uid);
      allow create: if isSignedIn() &&
        request.resource.data.status == "pending" &&
        request.resource.data.uploaded_by == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /admission_resources/{id} {
      allow read: if resource.data.status == "published" || isAdmin() ||
        (isSignedIn() && resource.data.uploaded_by == request.auth.uid);
      allow create: if isSignedIn() &&
        request.resource.data.status == "pending" &&
        request.resource.data.uploaded_by == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /faqs/{id} {
      allow read: if resource.data.status == "published" || isAdmin() ||
        (isSignedIn() && resource.data.author_email == request.auth.token.email);
      allow create: if isSignedIn() &&
        request.resource.data.status == "pending" &&
        request.resource.data.answer == null;
      allow update, delete: if isAdmin();
    }

    match /events/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /societies/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /merit_history/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /testimonials/{id} {
      allow read: if resource.data.approved == true || isAdmin();
      allow write: if isAdmin();
    }

    match /stats/{id} {
      allow read: if true;
      allow write: if false;
    }

    match /bookmarks/{id} {
      allow read, delete: if isSignedIn() && resource.data.user_id == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.user_id == request.auth.uid;
    }

    match /event_registrations/{id} {
      allow read: if isSignedIn() &&
        (resource.data.user_id == request.auth.uid || isAdmin());
      allow create: if isSignedIn() &&
        request.resource.data.user_id == request.auth.uid;
      allow delete: if isSignedIn() &&
        (resource.data.user_id == request.auth.uid || isAdmin());
    }
  }
}
